{
  "manifest_version": 3,
  "name": "Ledgr Subscriptions",
  "version": "1.0.0",
  "description": "Track recurring subscriptions, see your true monthly cost, and never miss a renewal. A companion to Ledgr.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "alarms", "notifications"]
}
